APP_NAME=ASIS
APP_VERSION=4.0.0
ENVIRONMENT=development
DEBUG=false

FRONTEND_URL=http://localhost:3001
FRONTEND_INTERNAL_URL=http://frontend:3000
NEXT_PUBLIC_API_URL=http://localhost:8000
ALLOWED_ORIGINS=http://localhost:3001

DATABASE_URL=postgresql+psycopg://asis:asis@postgres:5432/asis
JWT_SECRET=replace-with-a-64-char-secret
ACCESS_TOKEN_EXPIRY_MINUTES=15
REFRESH_TOKEN_EXPIRY_DAYS=7
SECURE_COOKIES=false

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
RUN_ANALYSES_INLINE=false
LOCAL_WORKER_CONCURRENCY=4

LITELLM_PROXY_URL=http://litellm:4000
LITELLM_MASTER_KEY=replace-with-litellm-master-key
LITELLM_MODEL_PRIMARY=claude-sonnet-4-5
LITELLM_MODEL_FAST=claude-haiku-4-5
LITELLM_MODEL_GEMINI_PRO=gemini-2.5-pro
LITELLM_MODEL_GEMINI_FLASH=gemini-2.0-flash
LITELLM_MODEL_QWEN_STRATEGY=qwen-strategy
LITELLM_MODEL_PHI_REASONING=phi-4-reasoning
LITELLM_MODEL_ARCTIC_RESEARCH=arctic-research
LITELLM_MODEL_LLAMA_GOVERNANCE=llama-governance
EMBEDDING_MODEL=text-embedding-3-small
ASIS_DEMO_MODE=false

AGENT_MODEL_ORCHESTRATOR=claude-haiku-4-5
AGENT_MODEL_ORCHESTRATOR_FALLBACK=gemini-2.0-flash
AGENT_MODEL_ORCHESTRATOR_OPEN=qwen-strategy
AGENT_MODEL_STRATEGIST=gemini-2.5-pro
AGENT_MODEL_STRATEGIST_FALLBACK=claude-sonnet-4-5
AGENT_MODEL_STRATEGIST_OPEN=qwen-strategy
AGENT_MODEL_QUANT=gemini-2.5-pro
AGENT_MODEL_QUANT_FALLBACK=phi-4-reasoning
AGENT_MODEL_QUANT_OPEN=phi-4-reasoning
AGENT_MODEL_MARKET_INTEL=gemini-2.0-flash
AGENT_MODEL_MARKET_INTEL_FALLBACK=gemini-2.5-pro
AGENT_MODEL_MARKET_INTEL_OPEN=arctic-research
AGENT_MODEL_COMPETITOR_ANALYSIS=
AGENT_MODEL_COMPETITOR_ANALYSIS_FALLBACK=
AGENT_MODEL_COMPETITOR_ANALYSIS_OPEN=
AGENT_MODEL_RISK=claude-sonnet-4-5
AGENT_MODEL_RISK_FALLBACK=gemini-2.5-pro
AGENT_MODEL_RISK_OPEN=qwen-strategy
AGENT_MODEL_RISK_ASSESSMENT=
AGENT_MODEL_RISK_ASSESSMENT_FALLBACK=
AGENT_MODEL_RISK_ASSESSMENT_OPEN=
AGENT_MODEL_GEO_INTEL=
AGENT_MODEL_GEO_INTEL_FALLBACK=
AGENT_MODEL_GEO_INTEL_OPEN=
AGENT_MODEL_FINANCIAL_REASONING=
AGENT_MODEL_FINANCIAL_REASONING_FALLBACK=
AGENT_MODEL_FINANCIAL_REASONING_OPEN=
AGENT_MODEL_STRATEGIC_OPTIONS=
AGENT_MODEL_STRATEGIC_OPTIONS_FALLBACK=
AGENT_MODEL_STRATEGIC_OPTIONS_OPEN=
AGENT_MODEL_RED_TEAM=claude-sonnet-4-5
AGENT_MODEL_RED_TEAM_FALLBACK=gemini-2.5-pro
AGENT_MODEL_RED_TEAM_OPEN=llama-governance
AGENT_MODEL_ETHICIST=claude-sonnet-4-5
AGENT_MODEL_ETHICIST_FALLBACK=claude-haiku-4-5
AGENT_MODEL_ETHICIST_OPEN=llama-governance
AGENT_MODEL_COVE=gemini-2.5-pro
AGENT_MODEL_COVE_FALLBACK=claude-sonnet-4-5
AGENT_MODEL_COVE_OPEN=phi-4-reasoning
AGENT_MODEL_SYNTHESIS=claude-sonnet-4-5
AGENT_MODEL_SYNTHESIS_FALLBACK=gemini-2.5-pro
AGENT_MODEL_SYNTHESIS_OPEN=qwen-strategy

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
GCP_PROJECT_ID=
GCP_REGION=us-central1
VERTEXAI_PROJECT=
VERTEXAI_LOCATION=

OPEN_MODEL_API_BASE=
OPEN_MODEL_API_KEY=
OPEN_MODEL_QWEN_ID=qwen/qwen3-32b
OPEN_MODEL_PHI_ID=microsoft/phi-4
OPEN_MODEL_ARCTIC_ID=snowflake/arctic-instruct
OPEN_MODEL_LLAMA_GOVERNANCE_ID=meta-llama/llama-3.3-70b-instruct

QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
MEM0_API_KEY=
MEM0_BASE_URL=https://api.mem0.ai

TAVILY_API_KEY=
NEWSAPI_KEY=
FMP_API_KEY=

LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://langfuse:3000
LANGFUSE_TRACE_BASE_URL=http://localhost:3002

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:8000/api/v1/auth/google/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:8000/api/v1/auth/github/callback

N8N_WEBHOOK_SECRET=replace-with-n8n-secret
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=replace-with-n8n-password

SSE_PING_SECONDS=10
ENABLE_AUTO_SCHEMA=true
PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
PDF_MAX_PAGES=60
REPORT_COMPANY_LOGO_URL=

# Rate limiting
RATE_LIMIT_ANALYSES_PER_DAY=20
RATE_LIMIT_ANALYSES_PER_MINUTE=2

# Security
JWT_MIN_SECRET_LENGTH=32

# Observability and cost tracking
COST_TRACKING_ENABLED=true
LANGFUSE_ENABLED=false

# Database backup
BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=14
