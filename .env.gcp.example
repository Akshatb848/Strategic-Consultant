# Copy this file to `.env.gcp` on the GCP VM before the first launch.
# Replace every REPLACE_* value before running the deployment stack.

JWT_SECRET=REPLACE_WITH_STRONG_SECRET
FRONTEND_URL=http://REPLACE_WITH_VM_EXTERNAL_IP:3001
FRONTEND_INTERNAL_URL=http://frontend:3000
ALLOWED_ORIGINS=http://REPLACE_WITH_VM_EXTERNAL_IP:3001
NEXT_PUBLIC_API_URL=http://REPLACE_WITH_VM_EXTERNAL_IP:8000
PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium

# Optional OAuth provider credentials. When unset, the frontend will hide
# social sign-in flows and fall back to email/password authentication only.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://REPLACE_WITH_VM_EXTERNAL_IP:8000/api/v1/auth/google/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://REPLACE_WITH_VM_EXTERNAL_IP:8000/api/v1/auth/github/callback

DATABASE_URL=sqlite:////data/asis_v4.db
ASIS_DATA_DIR=/opt/asis/data

ENVIRONMENT=production
ASIS_DEMO_MODE=true
RUN_ANALYSES_INLINE=false
ENABLE_AUTO_SCHEMA=true
SECURE_COOKIES=false
LOCAL_WORKER_CONCURRENCY=1

BACKEND_PORT=8000
FRONTEND_PORT=3001

# Optional: set these when deploying prebuilt images from GitHub Actions.
# Leave them unset for local builds on the VM.
# BACKEND_IMAGE=ghcr.io/OWNER/REPO/asis-backend:latest
# FRONTEND_IMAGE=ghcr.io/OWNER/REPO/asis-frontend:latest
