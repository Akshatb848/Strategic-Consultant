NODE_ENV=development
PORT=8000
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
APP_NAME=ASIS
APP_VERSION=4.0.0

DATABASE_URL=postgresql://asis_user:STRONG_PASSWORD@localhost:5432/asis_v4

JWT_ACCESS_SECRET=replace_with_openssl_rand_hex_32_output
JWT_REFRESH_SECRET=replace_with_openssl_rand_hex_32_output
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

SESSION_SECRET=replace_with_openssl_rand_hex_32_output

GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:8000/api/auth/google/callback

GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_CALLBACK_URL=http://localhost:8000/api/auth/github/callback

ANTHROPIC_API_KEY=your_anthropic_api_key
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_MAX_TOKENS=2048

QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=asis_strategy_knowledge

REDIS_URL=redis://localhost:6379

RATE_LIMIT_LOGIN_MAX=10
RATE_LIMIT_LOGIN_WINDOW_MS=900000
RATE_LIMIT_SIGNUP_MAX=5
RATE_LIMIT_SIGNUP_WINDOW_MS=3600000
RATE_LIMIT_API_MAX=200
RATE_LIMIT_API_WINDOW_MS=60000

VITE_API_URL=http://localhost:8000
VITE_APP_NAME=ASIS
VITE_APP_VERSION=4.0.0
VITE_SOCKET_URL=http://localhost:8000
